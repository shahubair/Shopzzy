<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shopzy</title>
  <link rel="stylesheet" href="/css/theme.css" />
</head>
<body>

  <div class="container" style="max-width:700px;margin-top:120px;text-align:center;">

    <h1 style="font-size:48px;margin-bottom:10px;">Shopzy</h1>

    <p class="muted" style="font-size:18px;margin-bottom:28px;">
      Simple shopping platform 
    </p>

    <div style="display:flex;justify-content:center;gap:16px;flex-wrap:wrap;">

      <a
        href="/login"
        style="
          padding:12px 28px;
          border-radius:10px;
          background:#7c3aed;
          color:white;
          font-weight:600;
          text-decoration:none;
        "
      >
        Login
      </a>

      <a
        href="/signup"
        style="
          padding:12px 28px;
          border-radius:10px;
          background:#1f1f3a;
          color:#cfcfff;
          font-weight:600;
          text-decoration:none;
          border:1px solid #34346a;
        "
      >
        Signup
      </a>

    </div>

  </div>

  <div class="footer" style="margin-top:140px;text-align:center;">
    © Shopzy 
  </div>

</body>
</html>
