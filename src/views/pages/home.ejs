<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shopzy</title>
  <link rel="stylesheet" href="/css/theme.css" />
</head>
<body>

  <!-- NAVBAR -->
  <%- include("../partials/navbar", { user }) %>

  <div class="container">
    <% if (typeof session !== "undefined" && session.message) { %>
  <div
    style="
      background:#1f1f3a;
      border:1px solid #7c3aed;
      padding:10px;
      border-radius:8px;
      margin-bottom:16px;
      color:#eaeaf0;
    "
  >
    <%= session.message %>
  </div>
  <% session.message = null; %>
<% } %>


    <!-- USER INFO -->
    <p class="muted">Logged in as: <strong><%= user.role %></strong></p>

    <!-- CATEGORIES -->
    <h3>Categories</h3>
    <div class="categories">
      <a class="category <%= activeCategory === 'all' ? 'active' : '' %>" href="/home">
        All
      </a>

      <% if (categories && categories.length) { %>
        <% categories.forEach(cat => { %>
          <a
            class="category <%= activeCategory === cat ? 'active' : '' %>"
            href="/home?category=<%= cat %>">
            <%= cat %>
          </a>
        <% }) %>
      <% } %>
    </div>

    <!-- PRODUCTS -->
    <h3>Products</h3>

    <% if (!products || products.length === 0) { %>
      <p class="muted">No products found</p>
    <% } else { %>

      <div class="grid">
        <% products.forEach(p => { %>
          <div class="card">

            <% if (p.image) { %>
              <img src="<%= p.image %>" alt="<%= p.title %>" />
            <% } %>

            <div><strong><%= p.title %></strong></div>
            <div class="price">₹<%= p.price %></div>

            <% if (p.description) { %>
              <div class="muted"><%= p.description %></div>
            <% } %>

            <div class="muted"><%= p.category %></div>

            <!-- ✅ ADD TO CART (NEW) -->
            <a
              href="/cart/add/<%= p._id %>"
              style="
                display:inline-block;
                margin-top:10px;
                padding:8px 12px;
                background:#7c3aed;
                color:white;
                border-radius:8px;
                text-align:center;
              "
            >
              Add to Cart
            </a>

          </div>
        <% }) %>
      </div>

    <% } %>

  </div>

  <!-- FOOTER -->
  <div class="footer">© Shopzy</div>

  <!-- SEARCH SCRIPT -->
  <script src="/js/search.js"></script>

</body>
</html>
