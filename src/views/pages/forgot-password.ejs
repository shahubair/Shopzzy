<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Forgot Password | Shopzy</title>
  <link rel="stylesheet" href="/css/theme.css" />
</head>
<body>

  <div class="container" style="max-width:420px;margin-top:80px;">

    <h2 style="margin-bottom:20px;">Forgot Password</h2>

    <% if (error) { %>
      <p style="color:#ff4d4f;font-size:13px;margin-bottom:12px;">
        <%= error %>
      </p>
    <% } %>

    <form method="POST" action="/forgot-password">

      <div style="margin-bottom:18px;">
        <input
          name="email"
          placeholder="Enter your email"
          required
          style="
            width:100%;
            padding:10px;
            border-radius:8px;
            border:1px solid #2a2a5a;
            background:#0f0f1f;
            color:#eaeaf0;
          "
        />
      </div>

      <button
        type="submit"
        style="
          width:100%;
          padding:12px;
          border:none;
          border-radius:10px;
          background:#7c3aed;
          color:white;
          font-size:16px;
          font-weight:600;
          cursor:pointer;
        "
      >
        Send OTP
      </button>

    </form>

    <p class="muted" style="margin-top:16px;">
      <a href="/login">Back to login</a>
    </p>

  </div>

</body>
</html>
